# ─────────────────────────────────────────────────────────────
# QA Environment Configuration
# Copy this file to qa.env and fill in actual values
# ─────────────────────────────────────────────────────────────

# Core App
BASE_URL=https://print-qa.jcubhub.com
ENVIRONMENT=qa
ADMIN_PASSWORD=changeme-qa
LOG_LEVEL=DEBUG

# Paths (isolated via Docker volumes — these stay default)
DB_PATH=/data/app.db
UPLOAD_DIR=/uploads

# Session / Security (MUST differ from prod to prevent cross-auth)
SESSION_SECRET=generate-a-unique-random-string-for-qa
SECRET_KEY=generate-another-unique-random-string-for-qa

# Stripe — use TEST MODE keys (no real charges)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Shippo — use test API key
SHIPPO_API_KEY=shippo_test_...

# SMTP — use a test mailbox service (e.g., Mailtrap, Mailpit, etc.)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-pass
SMTP_FROM=qa@jcubhub.com

# Cloudflare Turnstile — use test keys or leave empty to disable
# Test keys: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# VAPID keys for push notifications (generate a separate pair for QA)
# python -c "from cryptography.hazmat.primitives.asymmetric import ec; from cryptography.hazmat.backends import default_backend; import base64; key = ec.generate_private_key(ec.SECP256R1(), default_backend()); pn = key.private_numbers(); pub = pn.public_numbers; print('VAPID_PRIVATE_KEY=' + base64.urlsafe_b64encode(pn.private_value.to_bytes(32, 'big')).decode().rstrip('=')); print('VAPID_PUBLIC_KEY=' + base64.urlsafe_b64encode(b'\\x04' + pub.x.to_bytes(32, 'big') + pub.y.to_bytes(32, 'big')).decode().rstrip('='))"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:qa@jcubhub.com

# Printellect device pairing — must point to QA domain
PRINTELLECT_PAIR_BASE_URL=https://print-qa.jcubhub.com

# Timezone
DISPLAY_TIMEZONE=America/New_York
